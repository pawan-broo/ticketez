{
  "name": "@ticketez/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "db:export": "tsx src/export-places.ts",
    "db:clear": "tsx src/clear-db.ts",
    "db:seed-analytics": "tsx src/seed-analytics.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.2",
    "tsdown": "catalog:",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.0",
    "pg": "^8.14.1",
    "zod": "catalog:"
  }
}
