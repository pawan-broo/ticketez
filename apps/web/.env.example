# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─── Auth (better-auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email via Google SMTP (Nodemailer) ───────────────────────────────────────
# Use a Gmail App Password (NOT your regular Gmail password)
# Setup: Gmail → Security → 2FA → App Passwords → create one for "Mail"
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=Ticketez

# ─── UPI Payment (shown on booking step 2) ───────────────────────────────────
# Leave empty until you have a UPI VPA — QR shows a placeholder box
NEXT_PUBLIC_UPI_VPA=
NEXT_PUBLIC_UPI_NAME=Ticketez

# ─── App URL (used in emails for QR code links) ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
